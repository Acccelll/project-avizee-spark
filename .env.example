VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Email do administrador exibido em telas de acesso negado / solicitação.
VITE_ADMIN_EMAIL=admin@avizee.com.br

# Quando "true", a página /signup exige `?invite=<token>` na URL.
VITE_INVITE_ONLY=false

# Apenas em desenvolvimento — preenchem o botão de "Login rápido (dev)".
# O botão é eliminado do bundle de produção via import.meta.env.DEV.
VITE_DEV_EMAIL=
VITE_DEV_PASSWORD=

# Habilita o módulo Social (Instagram/LinkedIn). Defina como 'true' para ativar.
# Quando 'false' (padrão), o item aparece no menu com o badge "Em breve" e fica desabilitado.
VITE_FEATURE_SOCIAL=false
